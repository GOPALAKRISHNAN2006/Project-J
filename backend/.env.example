# ─────────────────────────────────────────────
#  JARVIS Backend — Environment Configuration
# ─────────────────────────────────────────────

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://jarvis:jarvis_secret_2024@localhost:5432/jarvis_db

# MongoDB
MONGODB_URL=mongodb://jarvis:jarvis_secret_2024@localhost:27017
MONGODB_DB=jarvis_db

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Security — CHANGE THIS IN PRODUCTION!
SECRET_KEY=jarvis-ultra-secret-key-stark-industries-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Provider
OPENAI_API_KEY=openaiapi
OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=your_gemini_api_key_here
DEFAULT_PROVIDER=gemini
DEFAULT_MODEL=gemini-3.5-flash

# Home Assistant
HASS_URL=http://homeassistant.local:8123
HASS_TOKEN=your-long-lived-access-token-here

# App
APP_NAME=JARVIS
DEBUG=true
BACKEND_PORT=8000
